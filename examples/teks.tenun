// Operasi teks
biar kalimat: teks = "  Tenun itu Bahasa Pemrograman  ";
biar bersih: teks = pangkas(kalimat);
cetak("[" + bersih + "]");
cetak(keBesar(bersih));
cetak(keKecil(bersih));

biar kata: []teks = pisah(bersih, " ");
cetak("jumlah kata: " + keTeks(panjang(kata)));
cetak("gabung: " + gabung(kata, "-"));
